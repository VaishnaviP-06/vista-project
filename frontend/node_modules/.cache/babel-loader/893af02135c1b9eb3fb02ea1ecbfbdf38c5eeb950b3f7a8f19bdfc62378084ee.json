{"ast":null,"code":"import{useState,useEffect}from'react';export function useIsMobile(){let breakpoint=arguments.length>0&&arguments[0]!==undefined?arguments[0]:768;const[isMobile,setIsMobile]=useState(typeof window!=='undefined'?window.innerWidth<=breakpoint:false);useEffect(()=>{const handler=()=>setIsMobile(window.innerWidth<=breakpoint);window.addEventListener('resize',handler);return()=>window.removeEventListener('resize',handler);},[breakpoint]);return isMobile;}","map":{"version":3,"names":["useState","useEffect","useIsMobile","breakpoint","arguments","length","undefined","isMobile","setIsMobile","window","innerWidth","handler","addEventListener","removeEventListener"],"sources":["C:/FieldProject/VISTA/frontend/src/hooks/useIsMobile.js"],"sourcesContent":["import { useState, useEffect } from 'react';\n\nexport function useIsMobile(breakpoint = 768) {\n  const [isMobile, setIsMobile] = useState(\n    typeof window !== 'undefined' ? window.innerWidth <= breakpoint : false\n  );\n\n  useEffect(() => {\n    const handler = () => setIsMobile(window.innerWidth <= breakpoint);\n    window.addEventListener('resize', handler);\n    return () => window.removeEventListener('resize', handler);\n  }, [breakpoint]);\n\n  return isMobile;\n}\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAE3C,MAAO,SAAS,CAAAC,WAAWA,CAAA,CAAmB,IAAlB,CAAAC,UAAU,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,GAAG,CAC1C,KAAM,CAACG,QAAQ,CAAEC,WAAW,CAAC,CAAGR,QAAQ,CACtC,MAAO,CAAAS,MAAM,GAAK,WAAW,CAAGA,MAAM,CAACC,UAAU,EAAIP,UAAU,CAAG,KACpE,CAAC,CAEDF,SAAS,CAAC,IAAM,CACd,KAAM,CAAAU,OAAO,CAAGA,CAAA,GAAMH,WAAW,CAACC,MAAM,CAACC,UAAU,EAAIP,UAAU,CAAC,CAClEM,MAAM,CAACG,gBAAgB,CAAC,QAAQ,CAAED,OAAO,CAAC,CAC1C,MAAO,IAAMF,MAAM,CAACI,mBAAmB,CAAC,QAAQ,CAAEF,OAAO,CAAC,CAC5D,CAAC,CAAE,CAACR,UAAU,CAAC,CAAC,CAEhB,MAAO,CAAAI,QAAQ,CACjB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}